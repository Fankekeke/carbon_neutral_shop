<view class='UCenter-bg' style="background-image: linear-gradient(45deg, #a3f3a3, #1ee649ef);height: 400rpx;">
    <block wx:if="{{!hasUserInfo}}">
        <!-- canIUseGetUserProfile判断当前版本是否支持wx.getUserProfile方法 -->
        <button wx:if="{{canIUseGetUserProfile}}" bindtap="getUserProfile" class="cu-btn round shadow">登陆</button>
        <button wx:else open-type="getUserInfo" bindgetuserinfo="getUserInfo">获取头像昵称</button>
    </block>
    <!-- 用户已经授权过直接展示头像和用户名，大家实际开发中这里可以换成别的操作 -->
    <block wx:else>
        <view class="cu-avatar round lg" style="background-image:url({{userInfo.avatar}});"></view>
        <view class='text-xl' style="margin-top: 15px;font-size: 15px">{{userInfo.userName}}</view>
        <!-- <view class='margin-top-sm'>
            <text style="font-size: 13px" wx:if="{{userInfo.type == 1}}">普通会员</text>
        </view> -->
    </block>
</view>

<view wx:if="{{dataMap != null}}">
    <!-- 碳排放数据展示区域 -->
    <view class="carbon-data-container radius bg-white margin-top">
        <view class="carbon-header padding">
            <view class="flex justify-between align-center">
                <view class="text-xl text-bold text-green">🌱 我的环保贡献</view>
                <view class="cu-tag bg-green radius sm">环保达人</view>
            </view>
        </view>

        <!-- 总减碳量 -->
        <view class="carbon-total padding-lr">
            <view class="flex justify-center align-center padding-bottom">
                <view class="text-center">
                    <view class="text-green text-xxl">{{dataMap.totalCarbonReduction}}</view>
                    <view class="text-gray text-sm">累计减碳量(kg)</view>
                </view>
            </view>
        </view>

        <!-- 月度对比 -->
        <view class="carbon-monthly padding-lr padding-bottom">
            <view class="flex justify-between text-center">
                <view class="flex-sub">
                    <view class="text-orange text-xl">{{dataMap.currentMonthCarbonReduction}}</view>
                    <view class="text-gray text-sm">本月减碳</view>
                </view>
                <view class="flex-sub">
                    <view class="text-blue text-xl">{{dataMap.lastMonthCarbonReduction}}</view>
                    <view class="text-gray text-sm">上月减碳</view>
                </view>
                <view class="flex-sub">
                    <view class="text-{{dataMap.carbonReductionComparison >= 0 ? 'green' : 'red'}} text-xl">
                        {{dataMap.carbonReductionComparison >= 0 ? '+' : ''}}{{dataMap.carbonReductionComparison}}
                    </view>
                    <view class="text-gray text-sm">环比变化</view>
                </view>
            </view>
        </view>

        <!-- 环保等效展示 -->
        <view class="carbon-equivalent padding solid-top">
            <view class="text-center text-gray text-sm margin-bottom">环保贡献等效于</view>
            <view class="flex flex-wrap justify-between">
                <view class="equivalent-item text-center margin-bottom-sm">
                    <view class="text-green ">{{dataMap.drivingHoursEquivalent}}</view>
                    <view class="text-gray text-sm">小时驾车</view>
                </view>
                <view class="equivalent-item text-center margin-bottom-sm">
                    <view class="text-green ">{{dataMap.treesPlantedEquivalent}}</view>
                    <view class="text-gray text-sm">棵树一年</view>
                </view>
                <view class="equivalent-item text-center margin-bottom-sm">
                    <view class="text-green">{{dataMap.elevatorRidesEquivalent}}</view>
                    <view class="text-gray text-sm">次乘梯</view>
                </view>
            </view>
        </view>

        <!-- 环保进度条 -->
        <view class="carbon-progress padding-lr padding-top">
            <view class="text-gray text-sm margin-bottom">本月环保目标完成度</view>
            <view class="cu-progress radius striped active">
                <view class="bg-green" style="width:{{dataMap.currentMonthCarbonReduction > 10 ? 100 : (dataMap.currentMonthCarbonReduction * 10)}}%"></view>
            </view>
            <view class="flex justify-between text-gray text-sm margin-top-xs">
                <text>0kg</text>
                <text>10kg+</text>
            </view>
        </view>
    </view>
</view>
<view class="cu-list menu card-menu margin-top-xl margin-bottom-xl shadow-lg">
    <view class="cu-item arrow">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/order/index/index">
            <text class='icon-send text-cyan'></text>
            <text class='text-grey'>我的订单</text>
        </navigator>
    </view>
     <view class="cu-item arrow">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/vipcard/index/index">
            <text class='icon-vipcard text-green'></text>
            <text class='text-grey'>积分物品</text>
        </navigator>
    </view>
    <view class="cu-item arrow">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/vipcard/record/index">
            <text class='icon-record text-green'></text>
            <text class='text-grey'>兑换记录</text>
        </navigator>
    </view>
    <view class="cu-item arrow">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/coupon/index/index">
            <text class='icon-ticket text-red'></text>
            <text class='text-grey'>社区论坛</text>
        </navigator>
    </view>
    <view class="cu-item arrow">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/user/address/index">
            <text class='icon-location text-orange'></text>
            <text class='text-grey'>地址管理</text>
        </navigator>
    </view>
     <view class="cu-item arrow" wx:if="{{userInfo.type == 2}}">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/user/goods/index">
            <text class='icon-vipcard text-green'></text>
            <text class='text-grey'>积分记录</text>
        </navigator>
    </view>
</view>
