/* 碳排放数据样式 */
.carbon-data-container {
    margin: -60rpx 20rpx 0 20rpx;
    position: relative;
    z-index: 100;
}

.carbon-header {
    border-bottom: 1rpx solid #f0f0f0;
}

.text-price {
    font-size: 48rpx;
    font-weight: bold;
}

.carbon-monthly .text-price {
    font-size: 36rpx;
}

.equivalent-item {
    width: 33.33%;
}

.carbon-progress {
    padding-bottom: 30rpx;
}

.carbon-progress .cu-progress {
    height: 20rpx;
}

.carbon-progress .cu-progress view {
    transition: width 1s ease;
}
